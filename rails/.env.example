# Copy to .env — loaded automatically in development (dotenv) and by
# `docker compose` for production variable substitution.

# ===== Twitter (X) OAuth 2.0 =====
# developer.x.com → Project → App → "User authentication settings" → OAuth 2.0
# (Client ID / Client Secret — NOT the OAuth 1.0a API Key / Consumer Key.)
# Register this callback URL there:
#   local dev:  http://localhost:3000/users/auth/twitter2/callback
#   production: <AUTH_URL>/users/auth/twitter2/callback
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=

# ===== OpenID Connect (OIDC) — optional, independent of Twitter =====
# Presence of OIDC_ISSUER turns OIDC login on. Either provider may be enabled
# alone or together; with neither set, the login page shows a "not configured"
# notice. discovery uses <OIDC_ISSUER>/.well-known/openid-configuration.
# The callback below must be registered at the IdP, and AUTH_URL must match the
# origin actually serving the app (the redirect_uri is built from AUTH_URL):
#   <AUTH_URL>/users/auth/openid_connect/callback
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Login button label (default: "OIDC 登录")
OIDC_DISPLAY_NAME=

# Settlement accounts: X usernames or numeric twitter ids, comma-separated.
# These accounts see the "管理" tab and may enter scores / settle matches.
SETTLER_USERNAMES=

# football-data.org API token for auto-syncing scores (free tier works).
# Leave empty to disable auto-sync — results can still be entered in /admin.
FOOTBALL_DATA_API_KEY=

# ===== Production (docker compose) only =====
# Session/signing secret. Generate with: openssl rand -hex 64
SECRET_KEY_BASE=
# Public base URL the app is reached at (OAuth callback base, WS origin,
# https detection). e.g. https://<machine>.<tailnet>.ts.net
AUTH_URL=http://localhost:8026

# ===== Scheduler =====
# Set to false to disable the built-in recurring jobs (odds/results/schedule).
RUN_SCHEDULER=true
# Override intervals in minutes:
# CRON_ODDS_MIN=60
# CRON_RESULTS_MIN=15
# CRON_SCHEDULE_MIN=1440

# Local development: uncomment to silence recurring jobs under bin/dev.
# SOLID_QUEUE_SKIP_RECURRING=true

# Local development ONLY: mock the X login so you can sign in without real
# Twitter credentials. Double-gated (development + this var); never active in
# test or production. Clicking "用 X 登录" then creates a real Devise session.
#   OMNIAUTH_MOCK=1 SETTLER_USERNAMES=tester bin/dev
# Optional: OMNIAUTH_MOCK_HANDLE (default tester), OMNIAUTH_MOCK_UID (default 10001).
# OMNIAUTH_MOCK=1
