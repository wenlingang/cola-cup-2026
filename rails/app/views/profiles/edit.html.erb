<section class="id-page">
  <%= render "profiles/tabs" %>
  <% @accounts.each do |account| %>
    <p class="lead">已用 <%= provider_label(account.provider) %> 登录<% if account.username.present? %> · @<%= account.username %><% end %></p>
  <% end %>

  <%= render "profiles/form", user: current_user %>

  <%= button_to "退出登录", destroy_user_session_path, method: :delete, form: { class: "signout" } %>
</section>
