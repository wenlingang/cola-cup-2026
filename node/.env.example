# Copy to .env (for docker compose) or .env.local (for local dev).

DB_PATH=./data/cup.db

# Settlement accounts: X usernames or numeric twitter_id, comma-separated.
# These logged-in accounts may enter results, settle matches and mark coke paid.
SETTLER_USERNAMES=

# football-data.org API token for auto-syncing scores/results (free tier works).
# Leave empty to disable auto-sync — results can still be entered manually in /admin.
FOOTBALL_DATA_API_KEY=

# In-process scheduler: set "true" to auto-run periodic jobs (lock / odds /
# results / schedule) without a host crontab. Intervals (minutes) are optional.
RUN_SCHEDULER=false
# CRON_ODDS_MIN=60
# CRON_RESULTS_MIN=15
# CRON_SCHEDULE_MIN=1440

# Auth.js (next-auth v5). Generate AUTH_SECRET with:  openssl rand -base64 33
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Public base URL the app is reached at (must match the registered OAuth callback).
#   local dev:      http://localhost:3000
#   tailscale prod: https://<your-machine>.<tailnet>.ts.net
AUTH_URL=http://localhost:3000

# Twitter / X — OAuth 2.0 Client ID & Secret from developer.x.com
#   → Project → App → "User authentication settings" → OAuth 2.0
#   (NOT the API Key / Consumer Key, which is OAuth 1.0a)
# Register this callback URL there:  <AUTH_URL>/api/auth/callback/twitter
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=

# Optional: serve /_next/static from Cloudflare Pages CDN. See CLOUDFLARE.md.
# Must be set at BUILD time. Leave empty to serve assets from the app itself.
# e.g. https://cup-assets.pages.dev
ASSET_PREFIX=

